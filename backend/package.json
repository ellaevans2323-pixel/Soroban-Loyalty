{
  "name": "soroban-loyalty-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage",
    "test:integration": "NODE_ENV=test jest --config jest.integration.config.ts --runInBand --coverage",
    "test:reward-query-plan": "NODE_ENV=test jest src/services/__tests__/reward.service.test.ts --runInBand",
    "seed:perf": "ts-node -r dotenv/config src/scripts/seed-campaigns-perf.ts",
    "test:perf:campaigns": "k6 run ../benchmarks/k6/get-campaigns.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.1054.0",
    "@sentry/node": "^8.0.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.10.1",
    "node-pg-migrate": "^7.0.0",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "sanitize-html": "^2.13.0",
    "swagger-jsdoc": "^6.2.8",
    "uuid": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.4.0",
    "eslint-plugin-security": "^4.0.0",
    "exit-x": "^0.2.2",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
